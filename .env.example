# ExamEdge environment variables — placeholder values only (see architecture.md)
# Copy to .env.local and fill in real values. Never commit secrets.

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host.neon.tech/examedge?sslmode=require

# Upstash Redis (rate limiting + cache)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Anthropic (server only — never NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-api03-placeholder

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-placeholder

# Auth.js v5
AUTH_SECRET=generate_with_openssl_rand_base64_32

# Vercel Cron protection
CRON_SECRET=generate_random_secret

# Cloudflare R2 (object storage)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=examedge-uploads

# Resend (email)
RESEND_API_KEY=re_placeholder

# Plausible analytics (browser-safe domain only)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=examedge.cm

# Sentry (Unit 31+)
SENTRY_DSN=https://placeholder@sentry.io/placeholder
